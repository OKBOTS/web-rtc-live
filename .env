# =============================================================================
# Airwave — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For Docker:
#   docker run --env-file .env -p 3000:3000 airwave
#
# For local dev the workflow already sets PORT and BASE_PATH automatically.
# You only need to supply the database connection string below.
# =============================================================================


# --- PostgreSQL ---------------------------------------------------------------
# Full connection string to your PostgreSQL server.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Examples:
#   Local:   postgresql://postgres:secret@localhost:5432/airwave
#   Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
#   Neon:    postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgresql://postgres:8078024604@mona@db.otwaqpljcqxitqcdfvzf.supabase.co:5432/postgres

# --- Application --------------------------------------------------------------
# Runtime environment — controls logging verbosity and some Express behaviour.
# Values: development | production
NODE_ENV=production

# Pino log level.
# Values: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info


# --- Ports (Docker) -----------------------------------------------------------
# NGINX_PORT is the port nginx listens on inside the container.
# Map it to whatever you like on the host:  -p 80:3000
# The API server always binds to internal port 8080 — do NOT change this.
NGINX_PORT=3000


# --- Frontend build (Docker / CI) --------------------------------------------
# BASE_PATH is consumed by Vite at build time.
# Use / unless you serve the app under a sub-path (e.g. /airwave/).
BASE_PATH=/
